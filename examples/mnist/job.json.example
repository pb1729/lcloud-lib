{
  "name": "mnist-live-test",
  "instance_type": "CHEAPEST_AVAILABLE_GPU_TYPE",
  "ssh_key_name": "YOUR_LAMBDA_SSH_KEY_NAME",
  "ssh_private_key": "~/.ssh/id_ed25519",
  "timeout_seconds": 900,
  "setup_allowance_seconds": 600,
  "stop_grace_seconds": 15,
  "command": "set -o pipefail; mkdir -p /home/ubuntu/mnist-output; python3 -u train.py --data-dir /lambda/nfs/YOUR_FILESYSTEM/datasets/mnist --output-dir /home/ubuntu/mnist-output --epochs 1000 --checkpoint-count 20 --checkpoint-interval-seconds 30 2>&1 | tee /home/ubuntu/mnist-output/training.log",
  "workdir": "/home/ubuntu/lcloud-mnist",
  "filesystem": "YOUR_FILESYSTEM",
  "uploads": [
    {
      "source": "examples/mnist/",
      "destination": "/home/ubuntu/lcloud-mnist/"
    }
  ],
  "checkpoint": {
    "source": "/home/ubuntu/mnist-output",
    "destination": "runs/lcloud-mnist/artifacts",
    "interval_seconds": 30,
    "sync_timeout_seconds": 120,
    "exclude": ["*.tmp", "*.partial"]
  }
}
